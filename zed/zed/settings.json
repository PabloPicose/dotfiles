// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "agent": {
    "dock": "left",
    "default_profile": "ask",
    "default_model": {
      "effort": "high",
      "provider": "copilot_chat",
      "model": "gpt-5.4",
      "enable_thinking": false
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "ssh_connections": [
    {
      "host": "indra",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/ppicos/dev/ARCOS300/Arcos300m"
          ]
        },
        {
          "paths": [
            "/home/ppicos/dev/NexusNodeFramework/./"
          ]
        },
        {
          "paths": [
            "/home/ppicos/dev/Ot/./"
          ]
        },
        {
          "paths": [
            "/home/ppicos/dev/proradsim_cpp"
          ]
        }
      ]
    }
  ],
  "debugger": {
    "dock": "right",
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 10,
  },
  "autosave": "on_focus_change",
  "session": {
    "trust_all_worktrees": true,
  },
  //"tab_size": 2,
  "show_edit_predictions": false, // Disable inline predictions from Copilot or other provider
  "theme": "Catppuccin Macchiato",
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
  },
  "inlay_hints": {
    "enabled": false, // Shows in 'grey' the function type arguments
  },
  "buffer_font_size": 16.0,
  //"buffer_font_family": "JetBrainsMono Nerd Font",
  "cursor_blink": false,
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "file_types": {
    "CMake": ["CMakeLists.txt"],
  },
